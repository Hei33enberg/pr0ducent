# Vite — public at build time (do not put secrets here)
# Copy to .env.local for local dev; set same keys in Vercel (primary) — see docs/VERCEL-SUPABASE-KROK-PO-KROKU.md

# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJ... (anon public key from Supabase → Settings → API)

# Optional footer link "VBP for builders" (public GitHub repo when published)
# VITE_VBP_PROTOCOL_URL=https://github.com/pr0ducent/vibecoding-broker-protocol

# Feature flags — set to "false" to disable (see src/lib/featureFlags.ts)
# VITE_FF_MARKETPLACE=false
# VITE_FF_MULTI_BUILDER_STREAM=false
# VITE_FF_BYOA=false
# Bridge Mode (VBP) — see docs/POP-BRIDGE-ARCHITECTURE.md (default off)
# VITE_FF_BRIDGE_MODE=false
# VITE_FF_BRIDGE_AGGRESSIVE=false
